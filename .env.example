# ====== Configuration Propre Quartier ======
# Copier ce fichier en .env puis adapter les valeurs.

# --- Base de donnees ---
DB_NAME=propre_quartier
DB_USER=pq_user
DB_PASSWORD=change_me_pq
DB_ROOT_PASSWORD=change_me_root

# --- Ports exposes sur la machine hote ---
WP_PORT=8080
PMA_PORT=8081

# --- URL publique du site (en local : http://localhost:8080) ---
WP_URL=http://localhost:8080

# --- Debug WordPress (1 en dev, 0 en prod) ---
WP_DEBUG=1

# --- Compte admin cree automatiquement par WP-CLI ---
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=admin_pq_2025
WP_ADMIN_EMAIL=admin@propre-quartier.sn
WP_SITE_TITLE=Propre Quartier
